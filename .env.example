# Prism Environment Variables
# Copy this to .env and fill in your actual values

# === LLM Provider ===
# OpenAI (GPT-4o) - recommended for accuracy
OPENAI_API_KEY=sk-your-api-key-here

# OR Groq (Llama 3.3 70B) - faster, free tier
# GROQ_API_KEY=gsk_your-api-key-here

# === Discord Integration (Optional) ===
DISCORD_TOKEN=your-discord-bot-token

# === Slack Integration (Optional) ===
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# === Database (local development) ===
# SQLite automatically created at specflow.db
# For PostgreSQL, set DATABASE_URL instead
# DATABASE_URL=postgresql://user:password@localhost:5432/prism

# === Server Configuration ===
STREAMLIT_SERVER_PORT=3002
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_CLIENT_TOOLBAR_MODE=minimal
STREAMLIT_LOGGER_LEVEL=info

# === Development ===
DEBUG=false
